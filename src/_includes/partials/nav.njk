<header class="site-header">
  <a class="site-title{% if site.logo %} site-title--logo{% endif %}" href="/">
    {% if site.logo %}
      <img class="site-logo" src="{{ site.logo }}" alt="{{ site.title }}" />
    {% else %}
      {{ site.title }}
    {% endif %}
  </a>
  <nav class="site-nav" aria-label="Primary">
    {% set current = page.url %}
    <a href="/"{% if current == "/" %} aria-current="page"{% endif %}>Home</a>
    <a href="/about/"{% if current == "/about/" %} aria-current="page"{% endif %}>About</a>
    <a href="/statement/"{% if current == "/statement/" %} aria-current="page"{% endif %}>Statement</a>
    <a href="/work/"{% if current.startsWith("/work/") %} aria-current="page"{% endif %}>Work</a>
    <a href="/cv/"{% if current == "/cv/" %} aria-current="page"{% endif %}>CV</a>
    <a href="/contact/"{% if current == "/contact/" %} aria-current="page"{% endif %}>Contact</a>
  </nav>
</header>
